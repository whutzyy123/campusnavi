# =============================================================================
# Campus Survival Guide — 环境变量模板
# 复制为 .env 并填写实际值。权威说明见 docs/开发规范.md、.env.example 内注释及 docs/代码修复建议.md §6.2
# =============================================================================

# --- 数据库（必填） ---
# MySQL 连接串，Prisma 通过 schema.prisma 读取
# 未配置：db:generate 可执行，但 db:push / 运行时 Prisma 连接失败
DATABASE_URL=mysql://user:password@localhost:3306/campus_survival

# --- 高德地图（地图页必填） ---
# Web 端 JS API Key；见 lib/geo/amap-loader.ts
# 未配置：loadAMap() 失败，地图/导航/POI 相关页面无法加载 SDK
NEXT_PUBLIC_AMAP_KEY=

# 安全密钥（JS API 2.0 推荐配置）；同上文件
# 未配置：仍尝试加载 SDK，但可能触发高德安全校验失败或功能受限
NEXT_PUBLIC_AMAP_SECURITY_KEY=

# --- 对象存储（图片上传必填） ---
# Vercel Blob 读写 Token；@vercel/blob put() 自动读取
# 未配置：POI/集市/广场等图片上传 Server Action 返回「上传失败」
BLOB_READ_WRITE_TOKEN=

# --- 认证 JWT（必填） ---
# 签发/校验 campus-auth-jwt；见 lib/auth/jwt.ts
# 未配置：登录后 signAuthJWT 抛错；Middleware 校验 JWT 失败，管理端重定向登录
JWT_SECRET=

# --- 定时任务 ---
# GET /api/cron/market-deadlock 请求头 Authorization: Bearer <CRON_SECRET>
# 未配置：production 返回 500，非 production 返回 401
CRON_SECRET=

# --- 开发 Seed 路由 ---
# POST /api/auth/seed、/api/auth/seed-test-accounts（生产环境本身禁用）
# 已配置：须 Bearer <SEED_SECRET>；未配置：仅 NODE_ENV=development 允许匿名，否则 401
SEED_SECRET=

# --- 反向代理 / 客户端 IP ---
# 为 true/1/yes 时信任 x-forwarded-for、x-real-ip；见 lib/auth/client-ip.ts
# 未配置或非 true/1/yes：仍使用 cf-connecting-ip、x-vercel-forwarded-for；通用转发头不信任
TRUST_PROXY=

# --- 数据埋点 ---
# 客户端是否启用 track() 上报；见 lib/analytics/index.ts
# 未配置或非 true/1：埋点静默关闭（开发环境仍 console.debug 输出）
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# GA4 Measurement ID（可选，启用 GA4 时配置）
# 未配置：不向 GA4 发送
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel Token（可选）
# 未配置：不向 Mixpanel 发送
# NEXT_PUBLIC_MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 自建埋点 API 地址（可选）
# 未配置：不向自建端点 POST
# NEXT_PUBLIC_ANALYTICS_API_URL=https://your-api.com/events

# --- 可选：运维 / 审计 ---
# 集市自动解锁等审计日志归属用户（须为超管 role=4）；见 lib/market/shared.ts
# 未配置：取 id 最小的 SUPER_ADMIN
# SYSTEM_AUDIT_USER_ID=
