# 数据埋点（参见 docs/数据埋点说明文档.md）
# 是否启用埋点（开发环境可设为 false）
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# GA4 Measurement ID（可选，启用 GA4 时配置）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel Token（可选，启用 Mixpanel 时配置）
# NEXT_PUBLIC_MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 自建埋点 API 地址（可选，启用自建上报时配置）
# NEXT_PUBLIC_ANALYTICS_API_URL=https://your-api.com/events

# 定时任务 /api/cron/market-deadlock：本地与生产均需配置；请求头 Authorization: Bearer <CRON_SECRET>
# 未配置时：生产返回 500，非生产返回 401
# CRON_SECRET=your-long-random-secret

# 置于可信反向代理后时开启，限流等逻辑才会信任 x-forwarded-for / x-real-ip（否则易伪造）
# 未配置或非 true/1/yes 时：仍可使用 cf-connecting-ip、x-vercel-forwarded-for 等平台注入头
# TRUST_PROXY=true

# 中间件内部请求 /api/auth/me 的站点基址（可选）；也可设 NEXT_PUBLIC_APP_URL；Vercel 会自动有 VERCEL_URL
# INTERNAL_APP_BASE_URL=http://localhost:3000

# 集市自动解锁/完成等审计日志的归属用户 ID（须为超级管理员 role=4）；未设置则取 id 最小的超管
# SYSTEM_AUDIT_USER_ID=

# 开发用 POST /api/auth/seed 与 /api/auth/seed-test-accounts：若设置则必须带 Authorization: Bearer <SEED_SECRET>
# SEED_SECRET=

